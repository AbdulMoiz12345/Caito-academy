# ---- Email delivery via Microsoft Graph (app-only / client credentials) ----
# The three values from your Azure app registration:
MS_TENANT_ID=your-tenant-id
MS_CLIENT_ID=your-application-client-id
MS_CLIENT_SECRET=your-client-secret-value

# Mailbox the email is SENT FROM (must be a real mailbox in your tenant)
MS_SENDER=salman.ansari@caito360.ai

# Where applications are delivered
TO_EMAIL=salman.ansari@caito360.ai
